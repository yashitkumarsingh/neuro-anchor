{
  "name": "neuro-anchor",
  "displayName": "Neuro-Anchor",
  "description": "Local-first AI developer support layer for ADHD, autistic, dyslexic, and cognitively overloaded developers.",
  "version": "0.1.0",
  "publisher": "neuro-anchor",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "neuro-anchor-sidebar",
          "title": "Neuro-Anchor",
          "icon": "$(anchor)"
        }
      ]
    },
    "views": {
      "neuro-anchor-sidebar": [
        {
          "type": "webview",
          "id": "neuro-anchor.sidebarView",
          "name": "Neuro-Anchor Companion"
        }
      ]
    },
    "commands": [
      {
        "command": "neuro-anchor.toggleFocusMode",
        "title": "Neuro-Anchor: Activate Focus Mode",
        "category": "Neuro-Anchor"
      },
      {
        "command": "neuro-anchor.toggleLowSensoryMode",
        "title": "Neuro-Anchor: Activate Low Sensory Mode",
        "category": "Neuro-Anchor"
      },
      {
        "command": "neuro-anchor.restoreStandardMode",
        "title": "Neuro-Anchor: Restore Standard Mode",
        "category": "Neuro-Anchor"
      },
      {
        "command": "neuro-anchor.toggleDND",
        "title": "Neuro-Anchor: Toggle Interruption Shield (DND)",
        "category": "Neuro-Anchor"
      }
    ],
    "configuration": {
      "title": "Neuro-Anchor Settings",
      "properties": {
        "neuroAnchor.ollamaUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "The URL of the local Ollama instance."
        },
        "neuroAnchor.ollamaModel": {
          "type": "string",
          "default": "llama3",
          "description": "The local Ollama model to use for generation."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && node esbuild.js",
    "watch": "node esbuild.js --watch",
    "build": "tsc -p ./ && node esbuild.js --minify",
    "test:unit": "node dist/test/suite.test.js && node dist/test/e2e.test.js",
    "test:coverage": "nyc node -e \"require('./dist/test/suite.test.js'); require('./dist/test/e2e.test.js');\""
  },
  "dependencies": {
    "@neuro-anchor/core": "file:../core"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "^18.11.18",
    "typescript": "^4.9.5",
    "esbuild": "^0.21.5",
    "nyc": "^15.1.0"
  }
}
